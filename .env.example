# Denox environment configuration.
# Copy this file to `.env` and adjust the values.
# Every variable is validated at startup (src/config/env.ts). Invalid values fail fast.

# development | test | production
APP_ENV=development

# HTTP server
PORT=8000
HOSTNAME=127.0.0.1
# Use 0.0.0.0 in production / Docker (bind on all interfaces).

# debug | info | warn | error
LOG_LEVEL=debug

# Comma separated list of allowed origins, or * for any (development only).
CORS_ORIGIN=*

# Rate limiting (per client IP, fixed window)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Request limits
MAX_BODY_SIZE_BYTES=1048576
REQUEST_TIMEOUT_MS=30000
