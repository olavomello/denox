```gitignore
# ==========================================================
# Denox
# .gitignore
# ==========================================================

# ----------------------------------------------------------
# Operating System
# ----------------------------------------------------------

.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------------------------------------
# IDEs
# ----------------------------------------------------------

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

.idea/
*.iml

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------

logs/
*.log
*.pid
*.seed
*.out
*.err

# ----------------------------------------------------------
# Environment
# ----------------------------------------------------------

.env
.env.*
!.env.example

# ----------------------------------------------------------
# Deno
# ----------------------------------------------------------

.deno/

# Deno Compile
*.exe
*.dll
*.so
*.dylib

# ----------------------------------------------------------
# Node (optional tooling)
# ----------------------------------------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------------------------
# Build
# ----------------------------------------------------------

dist/
build/
coverage/
reports/
tmp/
temp/
.cache/

# ----------------------------------------------------------
# Generated Files
# ----------------------------------------------------------

src/frontend/pages.gen.ts
src/frontend/routes.gen.ts
src/frontend/layouts.gen.ts
src/frontend/manifest.gen.ts
src/frontend/types.gen.ts

# ----------------------------------------------------------
# Documentation
# ----------------------------------------------------------

docs/generated/

# ----------------------------------------------------------
# Docker
# ----------------------------------------------------------

.docker/

# ----------------------------------------------------------
# Test
# ----------------------------------------------------------

.nyc_output/
coverage/

# ----------------------------------------------------------
# Runtime
# ----------------------------------------------------------

*.pid.lock

# ----------------------------------------------------------
# Security
# ----------------------------------------------------------

*.pem
*.key
*.crt
*.pfx
*.p12

# ----------------------------------------------------------
# Archives
# ----------------------------------------------------------

*.zip
*.tar
*.gz
*.rar
*.7z

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------

*.sqlite
*.sqlite3
*.db

# ----------------------------------------------------------
# Local Configuration
# ----------------------------------------------------------

.local/
.localrc

# ----------------------------------------------------------
# Backup
# ----------------------------------------------------------

*.bak
*.backup
*.old
*.orig
*.swp
*.swo

# ----------------------------------------------------------
# Mac
# ----------------------------------------------------------

.AppleDouble
.LSOverride

# ----------------------------------------------------------
# Linux
# ----------------------------------------------------------

*~

# ----------------------------------------------------------
# Windows
# ----------------------------------------------------------

ehthumbs.db

# ----------------------------------------------------------
# Framework Generated Files
# ----------------------------------------------------------

public/build/
public/cache/
storage/
```
