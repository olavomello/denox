{
  "tasks": {
    "routes": "deno run -A src/frontend/generate_routes.ts",
    "dev": "deno task routes && deno run -A --watch src/main.ts",
    "upgrade": "deno update --latest",
    "test": "deno test --allow-net --allow-read --allow-env --unstable",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check",
    "bundle": "deno bundle ./src/main.ts ./dist/bundle.js",
    "bundle-min": "deno bundle --minify ./src/main.ts ./dist/bundle.min.js",
    "bundle-dts": "deno bundle --unstable --no-check --config ./tsconfig.json ./src/main.ts ./dist/bundle.d.ts",
    "bundle-dts-min": "deno bundle --unstable --no-check --config ./tsconfig.json --minify ./src/main.ts ./dist/bundle.min.d.ts",
    "compile": "deno compile --unstable --allow-net --allow-read --allow-env --output ./dist/app ./src/main.ts",
    "compile-win": "deno compile --unstable --allow-net --allow-read --allow-env --output ./dist/win/app.exe ./src/main.ts",
    "compile-mac": "deno compile --unstable --allow-net --allow-read --allow-env --output ./dist/mac/app-mac ./src/main.ts",
    "compile-linux": "deno compile --unstable --allow-net --allow-read --allow-env --output ./dist/linux/app-linux ./src/main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/http": "jsr:@std/http@^1.0.19",
    "express": "npm:express@^5.2.1",
    "@/": "./src/",
    "hono": "npm:hono@^4.12.27",
    "jsr": "npm:jsr@^0.14.3",
    "std": "npm:std@^0.1.40"
  }
}
